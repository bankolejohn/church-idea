{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "links": [],
  "panels": [
    {
      "title": "CPU Usage",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "rate(churchcms_process_cpu_seconds_total[5m]) * 100",
          "legendFormat": "CPU %"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "custom": { "drawStyle": "line", "fillOpacity": 20 },
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 60 },
              { "color": "red", "value": 80 }
            ]
          }
        }
      }
    },
    {
      "title": "Memory Usage",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "churchcms_process_resident_memory_bytes",
          "legendFormat": "RSS"
        },
        {
          "expr": "churchcms_nodejs_heap_size_used_bytes",
          "legendFormat": "Heap Used"
        },
        {
          "expr": "churchcms_nodejs_heap_size_total_bytes",
          "legendFormat": "Heap Total"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "custom": { "drawStyle": "line", "fillOpacity": 10 }
        }
      }
    },
    {
      "title": "Event Loop Lag",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "churchcms_nodejs_eventloop_lag_seconds",
          "legendFormat": "Event Loop Lag"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.1 },
              { "color": "red", "value": 0.5 }
            ]
          }
        }
      }
    },
    {
      "title": "Database Connection Pool",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "churchcms_db_pool_active_connections",
          "legendFormat": "Active"
        },
        {
          "expr": "churchcms_db_pool_idle_connections",
          "legendFormat": "Idle"
        },
        {
          "expr": "churchcms_db_pool_waiting_clients",
          "legendFormat": "Waiting"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "custom": { "drawStyle": "line", "fillOpacity": 20 }
        }
      }
    },
    {
      "title": "Active Handles & File Descriptors",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "churchcms_nodejs_active_handles_total",
          "legendFormat": "Active Handles"
        },
        {
          "expr": "churchcms_process_open_fds",
          "legendFormat": "Open FDs"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "none" } }
    },
    {
      "title": "GC Duration",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "rate(churchcms_nodejs_gc_duration_seconds_sum[5m])",
          "legendFormat": "GC time/s"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "s" }
      }
    }
  ],
  "schemaVersion": 39,
  "tags": ["church-cms", "infrastructure"],
  "templating": {
    "list": [
      {
        "name": "DS_PROMETHEUS",
        "type": "datasource",
        "query": "prometheus",
        "current": { "text": "Prometheus", "value": "Prometheus" }
      }
    ]
  },
  "time": { "from": "now-1h", "to": "now" },
  "title": "Church CMS - Infrastructure",
  "uid": "churchcms-infrastructure"
}
