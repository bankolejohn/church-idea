{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "links": [],
  "panels": [
    {
      "title": "Login Activity",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "sum(rate(churchcms_login_attempts_total{status=\"success\"}[5m])) * 60",
          "legendFormat": "Successful logins/min"
        },
        {
          "expr": "sum(rate(churchcms_login_attempts_total{status=\"failure\"}[5m])) * 60",
          "legendFormat": "Failed logins/min"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "custom": { "drawStyle": "line", "fillOpacity": 15 }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Failed logins/min" },
            "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }]
          }
        ]
      }
    },
    {
      "title": "Login Success Rate",
      "type": "gauge",
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "sum(rate(churchcms_login_attempts_total{status=\"success\"}[1h])) / sum(rate(churchcms_login_attempts_total[1h])) * 100",
          "legendFormat": ""
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 80 },
              { "color": "green", "value": 95 }
            ]
          }
        }
      }
    },
    {
      "title": "Total Logins Today",
      "type": "stat",
      "gridPos": { "h": 4, "w": 3, "x": 18, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "sum(increase(churchcms_login_attempts_total{status=\"success\"}[24h]))",
          "legendFormat": ""
        }
      ],
      "fieldConfig": { "defaults": { "unit": "none" } }
    },
    {
      "title": "Failed Logins Today",
      "type": "stat",
      "gridPos": { "h": 4, "w": 3, "x": 18, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "sum(increase(churchcms_login_attempts_total{status=\"failure\"}[24h]))",
          "legendFormat": ""
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 10 },
              { "color": "red", "value": 50 }
            ]
          }
        }
      }
    },
    {
      "title": "Members Created Over Time",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "sum(increase(churchcms_members_created_total[1h]))",
          "legendFormat": "Members added/hour"
        },
        {
          "expr": "sum(increase(churchcms_members_deleted_total[1h]))",
          "legendFormat": "Members removed/hour"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "custom": { "drawStyle": "bars", "fillOpacity": 50 }
        }
      }
    },
    {
      "title": "Branches Created (Total)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "sum(churchcms_branches_created_total) or vector(0)",
          "legendFormat": ""
        }
      ],
      "fieldConfig": { "defaults": { "unit": "none" } }
    },
    {
      "title": "Pastor Accounts Created (Total)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "sum(churchcms_pastor_accounts_created_total) or vector(0)",
          "legendFormat": ""
        }
      ],
      "fieldConfig": { "defaults": { "unit": "none" } }
    },
    {
      "title": "Members Added by Branch",
      "type": "piechart",
      "gridPos": { "h": 8, "w": 8, "x": 12, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "sum(increase(churchcms_members_created_total[24h])) by (branch_id)",
          "legendFormat": "Branch {{branch_id}}"
        }
      ]
    },
    {
      "title": "Application Version",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "churchcms_app_info",
          "legendFormat": "{{version}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [{ "options": { "1": { "text": "v${__series.name}" } }, "type": "value" }]
        }
      }
    }
  ],
  "schemaVersion": 39,
  "tags": ["church-cms", "business"],
  "templating": {
    "list": [
      {
        "name": "DS_PROMETHEUS",
        "type": "datasource",
        "query": "prometheus",
        "current": { "text": "Prometheus", "value": "Prometheus" }
      }
    ]
  },
  "time": { "from": "now-24h", "to": "now" },
  "title": "Church CMS - Business KPIs",
  "uid": "churchcms-business-kpis"
}
